{
    "name": "node-red-project",
    "description": "A Node-RED Project",
    "version": "0.0.1",
    "private": true,
    "main": "start.js",
    "bin": "start.js",
    "scripts": {
        "start": "node-red -s settings.js flows.json",
        "build": "pkg . --output dist/Jetpace.exe --icon icon/jetpace.ico"
    },
    "pkg": {
        "assets": [
            "flows.json",
            "settings.js",
            "node_modules/**/*",
            "public/**/*"
        ],
        "targets": [
            "node18-win-x64"
        ],
        "outputPath": "dist",
        "icon": "icon/jetpace.ico"
    },
    "dependencies": {
        "@flowfuse/node-red-dashboard": "~1.30.2",
        "@flowfuse/node-red-dashboard-2-ui-led": "~1.1.0",
        "@flowfuse/node-red-dashboard-2-user-addon": "~1.1.0",
        "@omrid01/node-red-dashboard-2-table-tabulator": "~0.8.2",
        "@s1seven/node-red-generate-pdf": "~0.0.9",
        "node-red": "^4.0.9",
        "node-red-contrib-chartjs": "~0.5.2",
        "node-red-contrib-chartjs-line-alt": "~0.0.1",
        "node-red-contrib-modbus": "~5.45.2",
        "node-red-contrib-mssql-plus": "~0.13.1",
        "node-red-contrib-pdfmake": "~1.1.0",
        "node-red-contrib-remote": "~2.0.5",
        "node-red-contrib-ui-led": "~0.4.11",
        "node-red-dashboard": "~3.6.6",
        "node-red-node-email": "~5.2.3",
        "node-red-node-mysql": "~3.0.0",
        "node-red-node-ui-table": "~0.4.5",
        "nodemailer": "^8.0.5",
        "pdf-red": "~0.0.4"
    }
}
